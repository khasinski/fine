<div class="max-w-4xl mx-auto">
  <div class="mb-6">
    <a href="/" class="text-blue-600 hover:text-blue-800">← Back to Dashboard</a>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <div class="flex justify-between items-start mb-6">
      <div>
        <h1 class="text-xl font-bold text-gray-900">
          <%= @session.type.to_s.gsub('_', ' ').capitalize %> Training
        </h1>
        <p class="text-gray-500"><%= @session.config[:model_id] %></p>
      </div>
      <div class="flex items-center space-x-2">
        <span id="status-badge" class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
          <%= @session.status == :running ? 'bg-yellow-100 text-yellow-800' :
              @session.status == :completed ? 'bg-green-100 text-green-800' :
              @session.status == :failed ? 'bg-red-100 text-red-800' :
              'bg-gray-100 text-gray-800' %>">
          <span id="status-text"><%= @session.status.to_s.capitalize %></span>
        </span>
        <% if @session.status == :running %>
        <form action="/training/<%= @session.id %>/cancel" method="POST" class="inline">
          <button type="submit" class="text-red-600 hover:text-red-800 text-sm">Cancel</button>
        </form>
        <% end %>
      </div>
    </div>

    <!-- Progress -->
    <div class="mb-6">
      <div class="flex justify-between text-sm text-gray-600 mb-1">
        <span>Epoch <span id="current-epoch"><%= @session.metrics[:current_epoch] || 0 %></span>/<%= @session.config[:epochs] %></span>
        <span>Loss: <span id="current-loss"><%= @session.metrics[:current_loss]&.round(4) || '-' %></span></span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-2">
        <div id="progress-bar" class="bg-blue-600 h-2 rounded-full transition-all duration-300"
             style="width: <%= (@session.metrics[:current_epoch] || 0) * 100.0 / @session.config[:epochs] %>%"></div>
      </div>
    </div>

    <!-- Loss Chart -->
    <div class="mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Training Loss</h2>
      <div class="bg-gray-50 rounded-lg p-4">
        <canvas id="loss-chart" height="200"></canvas>
      </div>
    </div>

    <!-- Metrics History -->
    <% if @session.history.any? %>
    <div class="mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Epoch History</h2>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Epoch</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Train Loss</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Val Loss</th>
            </tr>
          </thead>
          <tbody id="history-table" class="bg-white divide-y divide-gray-200">
            <% @session.history.each do |h| %>
            <tr>
              <td class="px-4 py-2 text-sm text-gray-900"><%= h[:epoch] %></td>
              <td class="px-4 py-2 text-sm text-gray-600"><%= h[:loss]&.round(4) || '-' %></td>
              <td class="px-4 py-2 text-sm text-gray-600"><%= h[:val_loss]&.round(4) || '-' %></td>
            </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
    <% end %>

    <!-- Actions (shown when complete) -->
    <div id="actions-section" class="<%= @session.status == :completed ? '' : 'hidden' %> border-t pt-6 mt-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Next Steps</h2>
      <div class="flex flex-wrap gap-4">
        <% if @session.type == :llm %>
        <a href="/inference/chat/<%= @session.id %>"
           class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">
          Test Chat
        </a>
        <% else %>
        <a href="/inference/classify/<%= @session.id %>"
           class="bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700">
          Test Model
        </a>
        <% end %>
        <a href="/export/<%= @session.id %>"
           class="bg-gray-600 text-white px-4 py-2 rounded-md hover:bg-gray-700">
          Export Model
        </a>
      </div>
    </div>

    <!-- Error (shown on failure) -->
    <% if @session.status == :failed %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4 mt-6">
      <h3 class="text-red-800 font-medium">Training Failed</h3>
      <p class="text-red-700 text-sm mt-1"><%= @session.error %></p>
    </div>
    <% end %>
  </div>
</div>

<script>
// Initialize chart
const ctx = document.getElementById('loss-chart').getContext('2d');
const chart = new Chart(ctx, {
  type: 'line',
  data: {
    datasets: [{
      label: 'Loss',
      borderColor: '#3b82f6',
      backgroundColor: 'rgba(59, 130, 246, 0.1)',
      data: <%= @session.history.map { |h| { x: h[:epoch], y: h[:loss] } }.to_json %>,
      tension: 0.1,
      fill: true
    }]
  },
  options: {
    responsive: true,
    maintainAspectRatio: false,
    scales: {
      x: {
        type: 'linear',
        title: { display: true, text: 'Epoch' }
      },
      y: {
        title: { display: true, text: 'Loss' },
        beginAtZero: false
      }
    },
    plugins: {
      legend: { display: false }
    },
    animation: { duration: 0 }
  }
});

// Live updates via SSE
<% if @session.status == :running %>
const eventSource = new EventSource('/events/<%= @session.id %>');
let batchLosses = [];

eventSource.addEventListener('batch_end', (e) => {
  const data = JSON.parse(e.data);
  document.getElementById('current-loss').textContent = data.loss.toFixed(4);
  batchLosses.push(data.loss);
});

eventSource.addEventListener('epoch_end', (e) => {
  const data = JSON.parse(e.data);

  // Update progress
  document.getElementById('current-epoch').textContent = data.epoch;
  document.getElementById('progress-bar').style.width =
    (data.epoch / <%= @session.config[:epochs] %> * 100) + '%';

  // Update chart
  chart.data.datasets[0].data.push({ x: data.epoch, y: data.metrics.loss });
  chart.update('none');

  // Update table
  const tbody = document.getElementById('history-table');
  const row = document.createElement('tr');
  row.innerHTML = `
    <td class="px-4 py-2 text-sm text-gray-900">${data.epoch}</td>
    <td class="px-4 py-2 text-sm text-gray-600">${data.metrics.loss?.toFixed(4) || '-'}</td>
    <td class="px-4 py-2 text-sm text-gray-600">${data.metrics.val_loss?.toFixed(4) || '-'}</td>
  `;
  tbody.appendChild(row);

  batchLosses = [];
});

eventSource.addEventListener('training_end', (e) => {
  const data = JSON.parse(e.data);
  eventSource.close();

  // Update status
  const badge = document.getElementById('status-badge');
  const statusText = document.getElementById('status-text');

  if (data.status === 'completed') {
    badge.className = badge.className.replace(/bg-\w+-100 text-\w+-800/, 'bg-green-100 text-green-800');
    statusText.textContent = 'Completed';
    document.getElementById('actions-section').classList.remove('hidden');
  } else {
    badge.className = badge.className.replace(/bg-\w+-100 text-\w+-800/, 'bg-red-100 text-red-800');
    statusText.textContent = 'Failed';
  }
});

eventSource.onerror = () => {
  console.log('SSE connection closed');
  eventSource.close();
};
<% end %>
</script>
