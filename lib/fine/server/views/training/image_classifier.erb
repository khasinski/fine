<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <a href="/" class="text-blue-600 hover:text-blue-800">← Back to Dashboard</a>
  </div>

  <div class="bg-white rounded-lg shadow p-6">
    <h1 class="text-xl font-bold text-gray-900 mb-6">Image Classification</h1>

    <form action="/training/start" method="POST" enctype="multipart/form-data" class="space-y-6">
      <input type="hidden" name="type" value="image_classifier">

      <!-- Model Selection -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Model</label>
        <select name="model_id" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
          <option value="google/siglip2-base-patch16-224">SigLIP2 Base 224 (fast)</option>
          <option value="google/siglip2-base-patch16-384">SigLIP2 Base 384 (balanced)</option>
          <option value="google/siglip2-large-patch16-256">SigLIP2 Large 256 (best)</option>
        </select>
      </div>

      <!-- Training Directory -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Training Directory</label>
        <input type="text" name="train_dir" placeholder="/path/to/train" required
               class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
        <p class="text-xs text-gray-500 mt-1">
          Directory with subdirectories for each class (e.g., train/cat/, train/dog/)
        </p>
      </div>

      <!-- Validation Directory -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Validation Directory (optional)</label>
        <input type="text" name="val_dir" placeholder="/path/to/val"
               class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
      </div>

      <!-- Basic Options -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Epochs</label>
          <input type="number" name="epochs" value="3" min="1" max="100"
                 class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Batch Size</label>
          <input type="number" name="batch_size" value="32" min="1" max="128"
                 class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
        </div>
      </div>

      <!-- Advanced Options -->
      <details class="border rounded-md">
        <summary class="px-4 py-2 cursor-pointer text-sm font-medium text-gray-700 hover:bg-gray-50">
          Advanced Options
        </summary>
        <div class="p-4 space-y-4 border-t bg-gray-50">
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Learning Rate</label>
              <input type="number" name="learning_rate" value="0.0002" step="0.00001"
                     class="w-full border-gray-300 rounded-md shadow-sm text-sm">
            </div>
          </div>
        </div>
      </details>

      <!-- Submit -->
      <div class="pt-4">
        <button type="submit"
                class="w-full bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 font-medium">
          Start Training
        </button>
      </div>
    </form>
  </div>
</div>
